{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/.well-known/verify.pem",
      "headers": [
        { "key": "Content-Type",  "value": "application/x-pem-file" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/.well-known/verification-policy.txt",
      "headers": [
        { "key": "Content-Type",  "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "celeste-homepage-webflow.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/faq", "destination": "/410.html", "statusCode": 410 },
    { "source": "/testimonials", "destination": "/410.html", "statusCode": 410 },
    { "source": "/user-settings", "destination": "/410.html", "statusCode": 410 },
    { "source": "/a-b-testing-start", "destination": "/410.html", "statusCode": 410 },
    { "source": "/pricing", "destination": "/410.html", "statusCode": 410 },
    { "source": "/basic-pricing", "destination": "/410.html", "statusCode": 410 },
    { "source": "/evolve-pricing", "destination": "/410.html", "statusCode": 410 },
    { "source": "/competitor-playbook-step-1", "destination": "/410.html", "statusCode": 410 },
    { "source": "/bio-optimiser", "destination": "/410.html", "statusCode": 410 },
    { "source": "/e-learning", "destination": "/410.html", "statusCode": 410 }
  ]
}
